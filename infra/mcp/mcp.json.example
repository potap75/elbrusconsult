  "mcpServers": {
    "buffer": {
      "url": "https://mcp.buffer.com/mcp",
      "headers": {
        "Authorization": "Bearer <YOUR_EXISTING_BUFFER_TOKEN>"
      }
    },
    "meta-ads": {
