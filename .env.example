# =========================================================================
# Elbrus Cloud - environment variables
# Copy this file to `.env` (at repo root) and adjust values for your env.
# =========================================================================

# Django -------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=elbrus.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Site metadata (used by SEO/JSON-LD) --------------------------------------
SITE_NAME=Elbrus Cloud
SITE_TAGLINE=Cloud Engineering & Cybersecurity Excellence
SITE_DOMAIN=localhost:8000
SITE_URL=http://localhost:8000
SITE_DEFAULT_OG_IMAGE=/static/img/og-default.png
SITE_TWITTER_HANDLE=@elbruscloud
INFO_EMAIL=info@elbruscloud.example
CONTACT_RECIPIENT_EMAIL=info@elbruscloud.example

# Database -----------------------------------------------------------------
# Dev default: SQLite if DATABASE_URL is unset.
# Production (Azure Postgres Flex) example:
#   postgres://USER:PASSWORD@HOST.postgres.database.azure.com:5432/elbrus?sslmode=require
DATABASE_URL=

# Email --------------------------------------------------------------------
# Dev default: console backend if these are unset.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Elbrus Cloud <no-reply@elbruscloud.example>

# Security (production) ----------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_CSRF_TRUSTED_ORIGINS=

# Sentry (optional) --------------------------------------------------------
SENTRY_DSN=
