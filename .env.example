# =========================================================================
# Elbrus Cloud - environment variables
# Copy this file to `.env` (at repo root) and adjust values for your env.
# =========================================================================

# Django -------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=elbrus.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Site metadata (used by SEO/JSON-LD) --------------------------------------
# Dev defaults below point at localhost so canonical / sitemap URLs are
# usable locally. Prod values live in /opt/elbrus/app/.env on the Azure VM
# and use https://elbruscloud.com — see infra/azure/README.md.
SITE_NAME=Elbrus Cloud
SITE_TAGLINE=Cloud Engineering & Cybersecurity Excellence
SITE_DOMAIN=localhost:8000
SITE_URL=http://localhost:8000
SITE_DEFAULT_OG_IMAGE=/static/img/og-default.png
SITE_TWITTER_HANDLE=@elbruscloud
INFO_EMAIL=info@elbruscloud.com
CONTACT_RECIPIENT_EMAIL=info@elbruscloud.com
SITE_ADVISORY_PHONE=+1 (704) 686-8481

# Database -----------------------------------------------------------------
# Dev default: SQLite if DATABASE_URL is unset.
# Production (Azure Postgres Flex) example:
#   postgres://USER:PASSWORD@HOST.postgres.database.azure.com:5432/elbrus?sslmode=require
DATABASE_URL=

# Email --------------------------------------------------------------------
# Dev default: console backend if these are unset.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Elbrus Cloud <no-reply@elbruscloud.example>

# Scheduling (booking calendar) -------------------------------------------
# Company timezone the weekly availability windows are interpreted in.
SCHEDULING_TIMEZONE=America/New_York
# Minimum lead time before a slot can be booked (in minutes).
SCHEDULING_MIN_LEAD_MINUTES=120
# Maximum lead time customers can book ahead (in days).
SCHEDULING_MAX_LEAD_DAYS=60
# Slot start times are aligned to this granularity inside an availability window.
SCHEDULING_SLOT_GRANULARITY_MINUTES=15

# Security (production) ----------------------------------------------------
# Production defaults are HTTPS-on with 1y HSTS. Override to False / 0 in
# local dev only.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_CSRF_TRUSTED_ORIGINS=https://elbruscloud.example,https://www.elbruscloud.example

# Rate limiting -----------------------------------------------------------
# django-ratelimit cannot read REMOTE_ADDR when Gunicorn runs behind Nginx
# via a Unix socket. In production, prod.py sets RATELIMIT_IP_META_KEY to
# HTTP_X_REAL_IP (the X-Real-IP header Nginx injects from $remote_addr).
# No env var is needed here; this is documented for reference only.

# Analytics & Tag Manager --------------------------------------------------
# Every value below is opt-in: blank means the corresponding script tag is
# not rendered and no third-party request fires. Keep ALL of them blank in
# dev unless you specifically want to test tag behaviour locally.
#
# Strategy: GTM is the single source of truth for all marketing tags in
# production (GA4, Google Ads, LinkedIn Insight, Meta Pixel, Microsoft UET,
# TikTok Pixel are all configured INSIDE the GTM container, not in this
# repo). Direct GA4 is a fallback for environments that don't run GTM.
GTM_CONTAINER_ID=
GA4_MEASUREMENT_ID=G-JD3TKNY687

# Paid-channel IDs. These don't render any scripts directly (GTM handles
# delivery); they're stored here so server-side code (offline conversion
# uploads, future ad-API integrations) can reference them.
GOOGLE_ADS_CONVERSION_ID=
LINKEDIN_PARTNER_ID=
META_PIXEL_ID=
BING_UET_TAG_ID=
TIKTOK_PIXEL_ID=

# Search engine site verification meta tags.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Google Consent Mode v2 defaults.
# Privacy-by-default: all signals default to denied until the visitor
# accepts via the consent banner. Set CONSENT_DEFAULT_GRANTED=True only if
# you have a compliance basis to imply consent (e.g. US-only audience).
# CONSENT_DEFAULT_DENY_REGIONS is a comma-separated list of ISO country
# codes where consent ALWAYS defaults to denied even if granted is the
# global default. Use for EEA/UK/CH where ePrivacy + GDPR require it.
CONSENT_DEFAULT_GRANTED=False
CONSENT_DEFAULT_DENY_REGIONS=

# Attribution capture -----------------------------------------------------
# How many days the first-touch attribution cookie persists. 90 is the
# industry-standard click attribution window for Google Ads.
ATTRIBUTION_COOKIE_DAYS=90

# Sentry (optional) --------------------------------------------------------
SENTRY_DSN=
