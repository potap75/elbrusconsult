{
  "name": "elbrus-frontend-build",
  "private": true,
  "version": "0.1.0",
  "description": "Tailwind build for the Elbrus Cloud Django templates",
  "scripts": {
    "build:css": "tailwindcss -i ./static/src/styles.css -o ./static/dist/styles.css --minify",
    "watch:css": "tailwindcss -i ./static/src/styles.css -o ./static/dist/styles.css --watch",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "tailwindcss": "^3.4.13",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47"
  }
}
